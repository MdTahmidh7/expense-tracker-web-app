# ----------------------------------------------------------------------------
# Maven Start Up Batch script
#
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
#
# Optional ENV vars
# -----------------
#   M2_HOME - location of maven2's installed home dir
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
#     e.g. to debug Maven itself, use
#       set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ----------------------------------------------------------------------------

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=$(which java 2>/dev/null)
  if [ -z "$JAVACMD" ] ; then
    echo "Error: JAVA_HOME is not defined and cannot find java in PATH." >&2
    exit 1
  fi
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

# Download and run maven-wrapper.jar
MAVEN_HOME="$HOME/.m2/wrapper/dists"
WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"

# Check if wrapper jar is present
if [ -f "$WRAPPER_JAR" ]; then
  exec "$JAVACMD" $MAVEN_OPTS \
    -classpath "$WRAPPER_JAR" \
    "-Dmaven.multiModuleProjectDirectory=$PWD" \
    org.apache.maven.wrapper.MavenWrapperMain "$@"
else
  echo "Error: $WRAPPER_JAR not found." >&2
  exit 1
fi
